# テーマ
theme = "Solarized Dark Higher Contrast"

# フォント
# 通常: 英字=JetBrains Mono / 日本語=BIZ UDGothic (Regular)
# 太字: 英字=JetBrains Mono Bold / 日本語=BIZ UDGothic Bold
# italic は通常を元にslant合成 / bold-italic は太字を明示指定
font-family = "JetBrains Mono"
font-family = "BIZ UDGothic"
font-family-bold = "JetBrains Mono"
font-family-bold = "BIZ UDGothic Bold"
font-family-bold-italic = "JetBrains Mono"
font-family-bold-italic = "BIZ UDGothic Bold"
font-size = 18
font-thicken = true

# 外観
background-opacity = 0.85
background-blur = 20
cursor-opacity = 0.8
cursor-color = ffffff
unfocused-split-opacity = 0.7

# ウィンドウ
window-padding-x = 4
window-padding-y = 4
window-padding-balance = true
window-save-state = always

# クリップボード
copy-on-select = clipboard
clipboard-paste-protection = true

# 入力・操作
focus-follows-mouse = true
mouse-scroll-multiplier = 2
# 行数ではなくバイト単位。10000000 ≒ 10MB/サーフェス（ghosttyのデフォルト値と同じ）
scrollback-limit = 10000000
shell-integration = detect

# 動作
confirm-close-surface = always

# macOS
macos-titlebar-style = tabs
macos-option-as-alt = true

# クイックターミナル
quick-terminal-position = top
quick-terminal-size = 40%
quick-terminal-autohide = true
